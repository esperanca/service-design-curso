<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {{ site.shortTitle }}{% else %}{{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ summary or site.description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <header class="site-header">
      <div class="wrapper site-header__inner">
        <a class="brand" href="/"><span class="mark">SD</span> {{ site.shortTitle }}</a>
        <nav class="nav" aria-label="Principal">
          <a href="/">Início</a>
          <a href="/aulas/curriculo/">Programa</a>
          <a href="/aulas/recursos-e-proximos-passos/">Recursos</a>
        </nav>
      </div>
    </header>

    <main id="conteudo">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="wrapper site-footer__inner">
        <p>{{ site.title }} — {{ site.tagline }}. Aprendendo em público.</p>
        <p>
          Por {{ site.author }} ·
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </p>
      </div>
    </footer>
  </body>
</html>
